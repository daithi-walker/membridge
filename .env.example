# Copy this to .env and fill in your values
# .env is git-ignored — never commit it

# GCP project for Vertex AI (used for auto-summary via Claude)
VERTEX_PROJECT_ID=your-gcp-project-id

# Vertex AI region — "global" works for Claude models
VERTEX_REGION=global

# Claude model used for session summaries (haiku = fast + cheap)
CLAUDE_SUMMARY_MODEL=claude-haiku-4-5-20251001

# Path to SQLite DB (default: ~/.claude-ui/sessions.db)
# CLAUDE_UI_DB=/custom/path/sessions.db
