# Copy this to .env and fill in your values
# .env is git-ignored — never commit it

# Anthropic API key (for auto-summary via Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Claude model used for session summaries (haiku = fast + cheap)
CLAUDE_SUMMARY_MODEL=claude-haiku-4-5-20251001

# Vertex AI (optional — alternative to ANTHROPIC_API_KEY)
# Set CLAUDE_CODE_USE_VERTEX=1 and provide your GCP project to use Vertex instead
# CLAUDE_CODE_USE_VERTEX=1
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# CLOUD_ML_REGION=global
